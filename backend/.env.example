# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=recruitment_platform

# Celery
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Application
APP_ENV=development
SECRET_KEY=your_secret_key_here
ALLOWED_ORIGINS=http://localhost:5173

# Gemini AI (optional)
GEMINI_API_KEY=your_gemini_key_here

# LinkedIn
LINKEDIN_SESSION_FILE=linkedin_session.json

# Scraping
MAX_CANDIDATES_PER_PLATFORM=30
SCRAPE_ENRICH_LIMIT=5
SCRAPE_DELAY_MIN=0.5
SCRAPE_DELAY_MAX=1.5
